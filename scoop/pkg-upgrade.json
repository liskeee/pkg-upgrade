{
    "version": "1.2.0",
    "description": "A cross-platform TUI that upgrades every package manager on your system",
    "homepage": "https://github.com/liskeee/pkg-upgrade",
    "license": "MIT",
    "depends": "python",
    "url": "https://github.com/liskeee/pkg-upgrade/releases/download/v1.2.0/pkg_upgrade-1.2.0-py3-none-any.whl",
    "hash": "c8495b1b6328595eaf38556e02f64053ddaabbfcfb826c6c29e69efb711ec115",
    "installer": {
        "script": [
            "$whl = \"$dir\\$(Split-Path -Leaf $url)\"",
            "python -m pip install --user --force-reinstall --no-deps \"$whl\" | Out-Null",
            "python -m pip install --user --upgrade textual PyYAML platformdirs | Out-Null"
        ]
    },
    "post_install": [
        "$comp = Join-Path $dir 'completions\\pkg-upgrade.ps1'",
        "Copy-Item -Force (Join-Path $dir 'src\\pkg_upgrade\\completions\\pkg-upgrade.ps1') $comp -ErrorAction SilentlyContinue",
        "$line = \". `\"$comp`\"\"",
        "if (-not (Test-Path $PROFILE)) { New-Item -ItemType File -Force -Path $PROFILE | Out-Null }",
        "if (-not (Select-String -Path $PROFILE -SimpleMatch -Pattern 'pkg-upgrade.ps1' -Quiet)) { Add-Content -Path $PROFILE -Value $line }"
    ],
    "uninstaller": {
        "script": [
            "if (Test-Path $PROFILE) { (Get-Content $PROFILE) -notmatch 'pkg-upgrade.ps1' | Set-Content $PROFILE }"
        ]
    },
    "bin": "pkg-upgrade.exe",
    "checkver": {
        "github": "https://github.com/liskeee/pkg-upgrade"
    },
    "autoupdate": {
        "url": "https://github.com/liskeee/pkg-upgrade/releases/download/v$version/pkg_upgrade-$version-py3-none-any.whl"
    }
}
